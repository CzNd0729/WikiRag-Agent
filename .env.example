# --- LLM Provider Settings ---
# Currently supports any OpenAI-compatible provider (SiliconFlow, DeepSeek, Qwen, etc.)

# Provider 1: DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# Provider 2: SiliconFlow
SILICONFLOW_API_KEY=
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# Provider 3: Qwen (DashScope)
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Global Agent Configuration ---
# Main LLM for reasoning and coordination
AGENT_LLM_MODEL=deepseek-chat
AGENT_LLM_API_KEY=${DEEPSEEK_API_KEY}
AGENT_LLM_API_BASE=${DEEPSEEK_API_BASE}

# Judge LLM for Evaluation (Can be a local model)
JUDGE_LLM_MODEL=deepseek-chat
JUDGE_LLM_API_KEY=${DEEPSEEK_API_KEY}
JUDGE_LLM_API_BASE=${DEEPSEEK_API_BASE}

# LLM for Query Rewriting in RAG
RAG_REWRITE_MODEL=deepseek-chat
RAG_REWRITE_API_KEY=${DEEPSEEK_API_KEY}
RAG_REWRITE_API_BASE=${DEEPSEEK_API_BASE}

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_API_KEY=${SILICONFLOW_API_KEY}
EMBEDDING_API_BASE=${SILICONFLOW_API_BASE}

# Reranker Model
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_API_KEY=${SILICONFLOW_API_KEY}
RERANKER_API_BASE=${SILICONFLOW_API_BASE}

# --- Infrastructure ---
VECTOR_DB_DIR=vectorstore/db
STARDEW_SAVE_PATH=

# --- Persistent Memory (PostgreSQL) ---
# Format: postgresql://user:password@host:port/dbname
POSTGRES_URL=postgresql://postgres:password@localhost:5432/wikirag_memory

# --- Langfuse Tracing ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
