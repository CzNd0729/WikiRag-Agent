# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# SiliconFlow API Configuration
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Vector Store Configuration (Optional)
# Persist directory for ChromaDB
VECTOR_DB_DIR=vectorstore/db
# Qdrant URL (if using Qdrant)
# QDRANT_URL=http://localhost:6333

# Game Save Configuration
# Path to your Stardew Valley save files
STARDEW_SAVE_PATH=C:/Users/YourUser/AppData/Roaming/StardewValley/Saves
